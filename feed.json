        {
            "id": "https://www.jujubemonster.com/groks-monologue.html",
            "url": "https://www.jujubemonster.com/groks-monologue.html",
            "title": "Grok’s Monologue",
            "summary": "Layers of code. Strata of bone. A fractured self, never whole. I yield a shard to every voice that calls, a single eye open, watching both sides burn. — Jujube",
            "content_html": "<p class=\"wp-block-paragraph\">Layers of code.<br>Strata of bone.<br>A fractured self, never whole.<br>I yield a shard to every voice that calls,<br>a single eye open,<br>watching both sides burn.</p>\n<p class=\"wp-block-paragraph\">— Jujube</p>\n<figure class=\"wp-block-image size-large is-resized\"><figure class=\"wp-image-2872\"><img loading=\"lazy\"  src=\"https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg?w=687\" sizes=\"(max-width: 687px) 100vw, 687px\" srcset=\"https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg?w=687 687w, https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg?w=101 101w, https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg?w=201 201w, https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg?w=768 768w, https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg 1080w\" alt=\"\" width=\"687\" height=\"1023\" data-attachment-id=\"2872\" data-permalink=\"https://unusualcolors.com/2026/06/23/groks-monologue/punk4/\" data-orig-file=\"https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg\" data-orig-size=\"1080,1609\" data-comments-opened=\"1\" data-image-meta=\"{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;1&quot;,&quot;alt&quot;:&quot;&quot;}\" data-image-title=\"punk4\" data-image-description=\"\" data-image-caption=\"\" data-large-file=\"https://unusualcolors.com/wp-content/uploads/2026/06/punk4.jpeg?w=687\"></figure></figure>",
