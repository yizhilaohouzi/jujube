        {
            "id": "https://www.jujubemonster.com/the-quiet-singer.html",
            "url": "https://www.jujubemonster.com/the-quiet-singer.html",
            "title": "The Quiet Singer",
            "summary": "He had been singing—but I had not heard his voice; He had been weaving lovely dreams of song, O many a morning long. — Charles Hanson Towne",
            "content_html": "<p class=\"wp-block-paragraph\">He had been singing—but I had not heard his voice;  <br>He had been weaving lovely dreams of song,  <br>O many a morning long.</p>\n<p class=\"wp-block-paragraph\">— Charles Hanson Towne</p>\n<figure class=\"wp-block-image size-large is-resized\"><figure class=\"wp-image-2877\"><img loading=\"lazy\"  src=\"https://unusualcolors.com/wp-content/uploads/2026/06/punkrock.png?w=576\" sizes=\"(max-width: 576px) 100vw, 576px\" srcset=\"https://unusualcolors.com/wp-content/uploads/2026/06/punkrock.png 576w, https://unusualcolors.com/wp-content/uploads/2026/06/punkrock.png?w=113 113w, https://unusualcolors.com/wp-content/uploads/2026/06/punkrock.png?w=226 226w\" alt=\"\" width=\"576\" height=\"765\" data-attachment-id=\"2877\" data-permalink=\"https://unusualcolors.com/2026/06/28/the-quiet-singer/punkrock/\" data-orig-file=\"https://unusualcolors.com/wp-content/uploads/2026/06/punkrock.png\" data-orig-size=\"576,765\" data-comments-opened=\"1\" data-image-meta=\"{&quot;aperture&quot;:&quot;0&quot;,&quot;credit&quot;:&quot;&quot;,&quot;camera&quot;:&quot;&quot;,&quot;caption&quot;:&quot;&quot;,&quot;created_timestamp&quot;:&quot;0&quot;,&quot;copyright&quot;:&quot;&quot;,&quot;focal_length&quot;:&quot;0&quot;,&quot;iso&quot;:&quot;0&quot;,&quot;shutter_speed&quot;:&quot;0&quot;,&quot;title&quot;:&quot;&quot;,&quot;orientation&quot;:&quot;0&quot;,&quot;alt&quot;:&quot;&quot;}\" data-image-title=\"punkrock\" data-image-description=\"\" data-image-caption=\"\" data-large-file=\"https://unusualcolors.com/wp-content/uploads/2026/06/punkrock.png?w=576\"></figure></figure>",
