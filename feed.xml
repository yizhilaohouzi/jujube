    <entry>
        <title>Ascending the Kuai Pavilion</title>
        <author>
            <name>Jujube</name>
        </author>
        <link href="https://www.jujubemonster.com/ascending-the-kuai-pavilion.html"/>
        <id>https://www.jujubemonster.com/ascending-the-kuai-pavilion.html</id>
        <media:content url="https://www.jujubemonster.com/media/posts/113/waterfall.jpeg" medium="image" />
            <category term="poetry"/>
            <category term="nature"/>
            <category term="Chinese poems"/>

        <updated>2026-07-19T13:43:00-07:00</updated>
            <summary type="html">
                <![CDATA[
                        <img src="https://www.jujubemonster.com/media/posts/113/waterfall.jpeg" alt="" />
                    落木千山天远大， 澄江一道月分明。 Fallen trees spread over a thousand mountains beneath a vast sky; One clear river reflects the bright moon. — Huang Tingjian 黄庭坚 (1045-1105)
                ]]>
            </summary>
        <content type="html">
            <![CDATA[
                    <p><img src="https://www.jujubemonster.com/media/posts/113/waterfall.jpeg" class="type:primaryImage" alt="" /></p>
                <p class="wp-block-paragraph">落木千山天远大，<br>澄江一道月分明。</p>
<p class="wp-block-paragraph">Fallen trees spread over a thousand mountains beneath a vast sky;<br>One clear river reflects the bright moon.</p>
<p class="wp-block-paragraph">— Huang Tingjian 黄庭坚 (1045-1105)</p>
