    <entry>
        <title>Mount Zhongnan</title>
        <author>
            <name>Jujube</name>
        </author>
        <link href="https://www.jujubemonster.com/mount-zhongnan.html"/>
        <id>https://www.jujubemonster.com/mount-zhongnan.html</id>
        <media:content url="https://www.jujubemonster.com/media/posts/112/hilly.png" medium="image" />
            <category term="poetry"/>
            <category term="nature"/>
            <category term="Chinese poems"/>

        <updated>2026-07-12T13:42:00-07:00</updated>
            <summary type="html">
                <![CDATA[
                        <img src="https://www.jujubemonster.com/media/posts/112/hilly.png" alt="" />
                    太乙近天都， 连山接海隅。 白云回望合， 青霭入看无。 Mount Zhongnan rises toward Heaven’s capital; Its ranges stretch to the edge of the sea. Looking back, white clouds close behind; Looking in, blue mist dissolves into nothing. — Wang Wei 王维 (701-761)
                ]]>
            </summary>
        <content type="html">
            <![CDATA[
                    <p><img src="https://www.jujubemonster.com/media/posts/112/hilly.png" class="type:primaryImage" alt="" /></p>
                <p class="wp-block-paragraph">太乙近天都，<br>连山接海隅。<br>白云回望合，<br>青霭入看无。</p>
<p class="wp-block-paragraph">Mount Zhongnan rises toward Heaven’s capital;<br>Its ranges stretch to the edge of the sea.<br>Looking back, white clouds close behind;<br>Looking in, blue mist dissolves into nothing.</p>
<p class="wp-block-paragraph">— Wang Wei 王维 (701-761)</p>
